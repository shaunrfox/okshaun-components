    "show_summary": true,
    "show_command": true,
    "save": "all"
  },
  {
    "label": "Standards check",
    "command": "npm",
    "args": ["run", "standards:check"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "show_summary": true,
    "show_command": true,
    "save": "all"
  }
]
